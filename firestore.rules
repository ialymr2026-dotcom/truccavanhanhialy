rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all client access to the config collection
    // This collection is only accessed by the server via firebase-admin
    match /config/{document=**} {
      allow read, write: if false;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
